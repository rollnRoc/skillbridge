# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="sqlserver://HOST:1433;database=SkillBridge;user=USER;password=PASSWORD;encrypt=true;trustServerCertificate=true"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-at-least-32-random-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-32-chars"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=3001
WEB_URL="http://localhost:3000"
NODE_ENV=development

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@skillbridge.com"

# ─── Storage (Cloudflare R2) ──────────────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="skillbridge-docs"
R2_PUBLIC_URL="https://..."

# ─── Payment ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET=""

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
WEB_URL=<WEB_PUBLIC_URL>
NEXT_PUBLIC_API_URL=<API_PUBLIC_URL>
ZX