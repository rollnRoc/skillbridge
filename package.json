{
  "name": "@org/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev:api": "nx serve api",
    "dev:web": "nx dev web",
    "build:api": "nx build @org/api --configuration=production",
    "start:api": "node apps/api/dist/main.js",
    "clean:web": "node -e \"try{require('fs').rmSync('apps/web/.next',{recursive:true,force:true});console.log('apps/web/.next temizlendi')}catch(e){console.log(e.message||e)}\"",
    "open:web": "start http://localhost:3000",
    "build": "nx run-many --target=build --projects=web,api",
    "test": "nx run-many --target=test --projects=api --parallel=1",
    "test:api": "nx test @org/api",
    "test:e2e": "nx e2e @org/api-e2e",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:studio": "prisma studio --schema=prisma/schema.prisma",
    "db:seed": "npx tsx prisma/seed.ts"
  },
  "private": true,
